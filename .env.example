# ============================================
# APEX SCREENER - Configuration
# ============================================

# --- Base de données ---
POSTGRES_USER=apex
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_DB=apex_screener
DATABASE_URL=postgresql://apex:changeme_strong_password@db:5432/apex_screener

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API Keys ---
# FRED (Federal Reserve Economic Data)
# Obtenir: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# Financial Modeling Prep
# Obtenir: https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=your_fmp_api_key_here

# --- Telegram Bot ---
# Créer un bot via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Configuration App ---
APP_ENV=production
LOG_LEVEL=INFO
FASTAPI_PORT=8000

# --- Rate Limiting (secondes entre requêtes) ---
FRED_RATE_LIMIT=1.0
FMP_RATE_LIMIT=12.0
SEC_RATE_LIMIT=0.15
DEFILLAMA_RATE_LIMIT=1.0

# --- Seuils d'alerte ---
INSIDER_MIN_AMOUNT=250000
ROIC_MIN_THRESHOLD=10.0
CRYPTO_MCAP_FDV_MIN_RATIO=0.4
TVL_SPIKE_THRESHOLD=20.0
